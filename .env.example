# ============================================================================
#  TFG-Tutor-Virtual — .env para Docker/Dokploy (PRODUCCIÓN)
#  Servidor: tutor-socratico.gnd.upv.es
# ============================================================================
# Copiar a .env y rellenar valores sensibles.
# Nunca commitear .env (esta en .gitignore).
#
# Stack post-migracion (abril 2026):
#   - PostgreSQL es la unica BD soportada (Mongo eliminado).
#   - LLM_MODE=upv usa el cluster Ollama de la UPV.

# ------------------------
# Frontend Build (Vite — solo Docker build)
# ------------------------
# En raiz / se dejan vacios. Si se monta en sub-path (ej: /v2), ajustar.
VITE_BASE_PATH=
VITE_BACKEND_URL=
VITE_DEV_BYPASS_AUTH=false

# ------------------------
# PostgreSQL
# ------------------------
PG_USER=postgres
PG_PASSWORD=CHANGEME_GENERATE_A_STRONG_PASSWORD
PG_DB=tutorvirtual
PG_PORT=5432

# ------------------------
# App
# ------------------------
APP_PORT=3001
SESSION_SECRET=CHANGEME_GENERATE_A_RANDOM_STRING_64CHARS

# ------------------------
# Ollama
# ------------------------
LLM_MODE=upv
OLLAMA_API_URL_UPV=https://ollama.gti-ia.upv.es:443
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_TEMPERATURE=0.4
HISTORY_MAX_MESSAGES=6
OLLAMA_KEEP_ALIVE=60m
OLLAMA_STREAM_MAX_MS=1800000
OLLAMA_TIMEOUT_MS=180000
OLLAMA_CLASSIFIER_MODEL=qwen2.5:latest
OLLAMA_CLASSIFIER_TIMEOUT_MS=120000
OLLAMA_INSECURE_TLS=0

# ------------------------
# ChromaDB
# ------------------------
CHROMA_PORT=8000

# ------------------------
# Debug / observability
# DEBUG_DUMP_CONTEXT a 1 solo cuando estes debuggeando algo concreto:
# escribe cada conversacion de cada alumno a disco (ruido + datos personales).
# ------------------------
DEBUG_OLLAMA=1
DEBUG_PIPELINE=1
AUDIT_LOG=1
DEBUG_DUMP_CONTEXT=0
DEBUG_DUMP_PATH=

# ------------------------
# Hexagonal refactor (orchestrator + budget)
# ------------------------
USE_ORCHESTRATOR=1
ORCHESTRATOR_BUDGET_MS=45000
GUARDRAIL_BUDGET_MS=45000
GUARDRAIL_MIN_RETRY_BUDGET_MS=10000

# ------------------------
# CAS OAuth2
# ------------------------
CAS_BASE_URL=https://caspre.upv.es/cas
OAUTH_CLIENT_ID=TUTOR-VIRTUAL
# 'dummy' funciona porque caspre lo acepta. Si UPV mueve a cas.upv.es real,
# pedir el secret a UPV y meterlo aqui.
OAUTH_CLIENT_SECRET=dummy
OAUTH_SCOPES=profile email
