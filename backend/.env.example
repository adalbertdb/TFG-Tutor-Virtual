# SOLO para desarrollo local con Node.js directo.
# En Docker estas variables se pasan via docker-compose environment.

# Copy this file to .env and fill in the sensitive values.
# Never commit .env (it's in .gitignore).
#
# Stack post-migracion (abril 2026):
#   - PostgreSQL es la unica BD soportada (Mongo eliminado).
#   - LLM_MODE=upv usa el cluster Ollama de la UPV; LLM_MODE=local usa Ollama
#     nativo en :11434 (tipicamente para tests offline).

# ------------------------
# Database (PostgreSQL — unica fuente)
# ------------------------
DATABASE_TYPE=postgresql
PG_CONNECTION_STRING=

# ------------------------
# General
# ------------------------
PORT=3001
NODE_ENV=production
SESSION_SECRET=
SERVER_BASE_URL=https://tutor-socratico.gnd.upv.es

# ------------------------
# Frontend (CORS y redirects)
# ------------------------
FRONTEND_BASE_URL=https://tutor-socratico.gnd.upv.es
WORKFLOW_BASE_URL=http://localhost:5174

# ------------------------
# Ollama
# ------------------------
LLM_MODE=upv
OLLAMA_API_URL_UPV=https://ollama.gti-ia.upv.es:443
OLLAMA_API_URL_LOCAL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_TEMPERATURE=0.4
HISTORY_MAX_MESSAGES=6
OLLAMA_KEEP_ALIVE=60m
OLLAMA_STREAM_MAX_MS=1800000
OLLAMA_TIMEOUT_MS=180000
OLLAMA_CLASSIFIER_MODEL=qwen2.5:latest
OLLAMA_CLASSIFIER_TIMEOUT_MS=120000
OLLAMA_INSECURE_TLS=0

# ------------------------
# Chroma
# ------------------------
CHROMA_URL=http://localhost:8000

# ------------------------
# Debug / observability
# ------------------------
DEBUG_OLLAMA=1
DEBUG_PIPELINE=1
AUDIT_LOG=1
DEBUG_DUMP_CONTEXT=0
DEBUG_DUMP_PATH=

# ------------------------
# Hexagonal refactor (orchestrator + budget P1c)
# ------------------------
USE_ORCHESTRATOR=1
ORCHESTRATOR_BUDGET_MS=45000
GUARDRAIL_BUDGET_MS=45000
GUARDRAIL_MIN_RETRY_BUDGET_MS=10000

# ------------------------
# CAS OAuth2
# ------------------------
CAS_BASE_URL=https://caspre.upv.es/cas
OAUTH_CLIENT_ID=TUTOR-VIRTUAL
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://tutor-socratico.gnd.upv.es/api/auth/cas/callback
OAUTH_SCOPES=profile email

# ------------------------
# Production with CAS
# ------------------------
DEV_BYPASS_AUTH=false
