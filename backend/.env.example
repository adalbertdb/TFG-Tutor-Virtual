# Copy this file to .env and fill in the sensitive values.
# Never commit .env (it's in .gitignore).

# ------------------------
# MongoDB
# ------------------------
# Format: mongodb+srv://USER:PASS@cluster.../DBNAME?retryWrites=true&w=majority
MONGODB_URI=

# ------------------------
# General
# ------------------------
PORT=3001
# Random long string — rotate if leaked
SESSION_SECRET=

# Public URL of the server (used for redirects)
SERVER_BASE_URL=https://tutor-virtual.dsic.upv.es/v2

# ------------------------
# Frontend (for CORS and redirects)
# ------------------------
FRONTEND_BASE_URL=https://tutor-virtual.dsic.upv.es/v2

# ------------------------
# Ollama
# ------------------------
LLM_MODE=upv
OLLAMA_API_URL_UPV=https://ollama.gti-ia.upv.es:443
OLLAMA_API_URL_LOCAL=https://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_TEMPERATURE=0.4
HISTORY_MAX_MESSAGES=6
OLLAMA_KEEP_ALIVE=60m
OLLAMA_STREAM_MAX_MS=1800000
OLLAMA_TIMEOUT_MS=180000
OLLAMA_CLASSIFIER_MODEL=qwen2.5:latest
OLLAMA_CLASSIFIER_TIMEOUT_MS=120000
OLLAMA_INSECURE_TLS=0

# ------------------------
# Debug / observability
# ------------------------
DEBUG_OLLAMA=1
DEBUG_PIPELINE=1
AUDIT_LOG=1
DEBUG_DUMP_CONTEXT=0
# Absolute path for raw prompt/message dumps when DEBUG_DUMP_CONTEXT=1
DEBUG_DUMP_PATH=

# ------------------------
# Hexagonal refactor (Phase 5)
# ------------------------
# Set to 1 to activate orchestrator + GuardrailPipeline.
# Set to 0 to fall back to the legacy ragMiddleware path.
USE_ORCHESTRATOR=1
GUARDRAIL_BUDGET_MS=45000
GUARDRAIL_MIN_RETRY_BUDGET_MS=10000
ORCHESTRATOR_BUDGET_MS=45000

# ------------------------
# CAS OAuth2
# ------------------------
CAS_BASE_URL=https://caspre.upv.es/cas
OAUTH_CLIENT_ID=TUTOR-VIRTUAL
# Provided by the CAS administrator
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://tutor-virtual.dsic.upv.es/v2/api/auth/cas/callback
OAUTH_SCOPES=profile email

# ------------------------
# Production with CAS
# ------------------------
# Set to "true" only in local development; never in production.
DEV_BYPASS_AUTH=false
